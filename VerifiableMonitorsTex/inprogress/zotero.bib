@inproceedings{hasuoGenericForwardBackward2006,
  title = {Generic {{Forward}} and {{Backward Simulations}}},
  booktitle = {{{CONCUR}} 2006 – {{Concurrency Theory}}},
  author = {Hasuo, Ichiro},
