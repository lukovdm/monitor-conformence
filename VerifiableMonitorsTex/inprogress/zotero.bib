@article{baierModelCheckingProbabilistic1998,
  title = {Model Checking for a Probabilistic Branching Time Logic with Fairness},
  author = {Baier, Christel and Kwiatkowska, Marta},
  date = {1998-08-01},
  journaltitle = {Distributed Computing},
  shortjournal = {Distrib Comput},
  volume = {11},
