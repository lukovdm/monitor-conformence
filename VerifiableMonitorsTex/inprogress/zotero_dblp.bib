@inproceedings{cleavelandConservativeSafetyMonitors2023,
    author = "Cleaveland, Matthew and Sokolsky, Oleg and Lee, Insup and Ruchkin, Ivan",
    editor = "Rozier, Kristin Yvonne and Chaudhuri, Swarat",
    title = "Conservative {{Safety Monitors}} of\textasciitilde {{Stochastic Dynamical Systems}}",
    booktitle = "{{NASA Formal Methods}}",
    date = "2023",
    pages = "140--156",
    publisher = "Springer Nature Switzerland",
    location = "Cham",
    doi = "10.1007/978-3-031-33170-1\_9",
    abstract = "Generating accurate runtime safety estimates for autonomous systems is vital to ensuring their continued proliferation. However, exhaustive reasoning about future behaviors is generally too complex to do at runtime. To provide scalable and formal safety estimates, we propose a method for leveraging design-time model checking results at runtime. Specifically, we model the system as a probabilistic automaton (PA) and compute bounded-time reachability probabilities over the states of the PA at design time. At runtime, we combine distributions of state estimates with the model checking results to produce a bounded time safety estimate. We argue that our approach produces well-calibrated safety probabilities, assuming the estimated state distributions are well-calibrated. We evaluate our approach on simulated water tanks.",
    isbn = "978-3-031-33170-1",
    langid = "english",
    keywords = "Calibrated Prediction,Probabilistic Model Checking,Runtime Monitoring",
    file = "/home/luko/Zotero/storage/8TMULP7T/Cleaveland et al. - 2023 - Conservative Safety Monitors of Stochastic Dynamical Systems.pdf"
}

